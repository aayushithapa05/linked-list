#include <stdio.h>
#include <stdlib.h>

// Structure of node
struct Node {
    int data;
    struct Node* next;
};

int main() {
    struct Node *start = NULL, *temp = NULL, *newNode;
    int n, i, value;

    printf("Enter number of elements: ");
    scanf("%d", &n);

    for(i = 1; i <= n; i++) {
        // Allocate memory for new node
        newNode = (struct Node*)malloc(sizeof(struct Node));

        printf("Enter data for node %d: ", i);
        scanf("%d", &value);

        newNode->data = value;
        newNode->next = NULL;

        if(start == NULL) {
            start = newNode;   
            temp = newNode;
        } else {
            temp->next = newNode;  
            temp = newNode;
        }
    }

    temp->next=start;
    temp = start;
    
     newNode = (struct Node*)malloc(sizeof(struct Node));
     printf("Enter the data to be inserted at the data ");
     scanf("%d",&value);
     newNode->data = value;
     newNode->next = NULL;
     
     while(temp->next!=start)
     {
        
         temp=temp->next;
     }
     temp->next=newNode;
     newNode->next=start;
     temp=start;
     
     do{
        printf("%d -> ", temp->data);
        temp = temp->next;
    }while(temp!=start);
     printf("NULL");
     
   

    return 0;
}
